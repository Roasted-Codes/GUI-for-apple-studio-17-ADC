#!/usr/bin/env python3
"""Button listener for Apple Studio Display 17" CRT (M7768).

Listens for the monitor's physical brightness button.
Press to open the GUI, press again to close it.
Runs as a desktop autostart service (headless).

Must run as root.
"""

import os
import subprocess
import sys
import threading

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from crt_backend import BUTTON_USAGE_E4, find_device, listen_buttons

INSTALL_DIR = "/usr/lib/crt-control"


def find_gui_path():
    gui_path = os.path.join(INSTALL_DIR, "pi-adc-gui.py")
    if not os.path.exists(gui_path):
        gui_path = os.path.join(
            os.path.dirname(os.path.abspath(__file__)), "pi-adc-gui.py")
    return gui_path


def get_gui_pids():
    """Return list of GUI process PIDs."""
    try:
        result = subprocess.run(
            ["pgrep", "-f", "pi-adc-gui.py"],
            capture_output=True, text=True, timeout=5)
        our_pid = os.getpid()
        return [int(p) for p in result.stdout.strip().splitlines()
                if int(p) != our_pid]
    except Exception:
        return []


def toggle_gui():
    """Open GUI if closed, close it if open."""
    pids = get_gui_pids()
    if pids:
        subprocess.run(["sudo", "pkill", "-9", "-f", "pi-adc-gui.py"],
                       capture_output=True, timeout=5)
    else:
        gui_path = find_gui_path()
        env = os.environ.copy()
        env["GDK_BACKEND"] = "wayland"
        env["WAYLAND_DISPLAY"] = "wayland-0"
        env["XDG_RUNTIME_DIR"] = "/run/user/1000"
        subprocess.Popen(
            ["python3", gui_path], env=env,
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def main():
    if os.geteuid() != 0:
        print("Must run as root.", file=sys.stderr)
        sys.exit(1)

    device = find_device()
    if not device:
        print("Apple Studio Display not found.", file=sys.stderr)
        sys.exit(1)

    def on_button(usage, value):
        if usage == BUTTON_USAGE_E4 and value != 0:
            threading.Thread(target=toggle_gui, daemon=True).start()

    listen_buttons(device, on_button)


if __name__ == "__main__":
    main()
