#!/usr/bin/env python3
"""Boot-time power-on for Apple Studio Display 17" CRT (M7768).

Waits for the monitor to appear on USB, powers it on, then exits.
Runs as a oneshot systemd service before the desktop session starts.

Must run as root.
"""

import os
import sys
import time
import logging

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from crt_backend import find_device, read_power, set_power

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [crt-daemon] %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger(__name__)


def wait_for_device(timeout=30):
    """Wait for the monitor to appear on USB. Returns device path or None."""
    for _ in range(timeout):
        device = find_device()
        if device:
            return device
        time.sleep(1)
    return None


def main():
    if os.geteuid() != 0:
        print("Must run as root.", file=sys.stderr)
        sys.exit(1)

    log.info("Waiting for Apple Studio Display...")
    device = wait_for_device()
    if not device:
        log.error("Monitor not found after 30s. Exiting.")
        sys.exit(1)

    log.info(f"Found monitor at {device}")

    state = read_power(device)
    if state != 1:
        log.info("Powering on monitor...")
        set_power(True)
        time.sleep(1)
        log.info("Monitor powered on.")
    else:
        log.info("Monitor already on.")


if __name__ == "__main__":
    main()
