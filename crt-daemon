#!/usr/bin/env python3
"""Background daemon for Apple Studio Display 17" CRT (M7768).

- Auto-powers on the monitor at startup
- Listens for brightness button → steps contrast through 5 levels
- Runs as a systemd service

Must run as root.
"""

import os
import sys
import time
import logging

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from crt_backend import (
    BUTTON_USAGE_E4, BRIGHTNESS_CODE, BRIGHTNESS_STEP,
    find_device, read_control, write_control,
    read_power, set_power, listen_buttons,
)

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [crt-daemon] %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger(__name__)


def wait_for_device(timeout=30):
    """Wait for the monitor to appear on USB. Returns device path or None."""
    for _ in range(timeout):
        device = find_device()
        if device:
            return device
        time.sleep(1)
    return None


def main():
    if os.geteuid() != 0:
        print("Must run as root.", file=sys.stderr)
        sys.exit(1)

    log.info("Waiting for Apple Studio Display...")
    device = wait_for_device()
    if not device:
        log.error("Monitor not found after 30s. Exiting.")
        sys.exit(1)

    log.info(f"Found monitor at {device}")

    # Auto power-on
    state = read_power(device)
    if state != 1:
        log.info("Powering on monitor...")
        set_power(True)
        time.sleep(1)
        log.info("Monitor powered on.")
    else:
        log.info("Monitor already on.")

    # Listen for button presses — brightness stepping
    log.info("Listening for brightness button (5 levels)...")

    def on_button(usage, value):
        if usage == BUTTON_USAGE_E4:
            current = read_control(BRIGHTNESS_CODE, device)
            if current is None:
                current = 0
            new_val = current + BRIGHTNESS_STEP
            if new_val > 96:
                new_val = 0
            write_control(BRIGHTNESS_CODE, new_val, device)
            log.info(f"Brightness: {current} -> {new_val}")

    try:
        listen_buttons(device, on_button)
    except OSError as e:
        log.error(f"Lost connection to monitor: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()
