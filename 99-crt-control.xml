<?xml version="1.0"?>
<!-- Super+M toggles Apple Studio Display power -->
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <keyboard>
    <keybind key="C-A-F12">
      <action name="Execute">
        <command>sudo /usr/bin/crt-toggle</command>
      </action>
    </keybind>
  </keyboard>
</openbox_config>
